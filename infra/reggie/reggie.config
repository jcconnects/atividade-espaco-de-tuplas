import com.sun.jini.start.ServiceDescriptor;
import com.sun.jini.start.NonActivatableServiceDescriptor;
import net.jini.config.ConfigurationException;

com.sun.jini.start {
    serviceDescriptors = new ServiceDescriptor[] {
        new NonActivatableServiceDescriptor(
            /* codebase — where clients download stub classes */
            "http://reggie:8080/reggie-dl.jar",
            /* security policy */
            "security.policy",
            /* classpath for the service itself */
            "reggie.jar:jsk-lib.jar:jsk-platform.jar",
            /* implementation class */
            "com.sun.jini.reggie.TransientRegistrarImpl",
            /* config args passed to reggie */
            new String[]{"reggie-inner.config"}
        )
    };
}
